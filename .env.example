APP_NAME=intelligent-learning-agent
APP_ENV=development
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/app.db
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File upload limit (MB)
FILE_UPLOAD_MAX_MB=80

SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=course_chunks
EMBEDDING_PROVIDER=hash_mock
EMBEDDING_DIM=384
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=mock
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_API_KEY=
SPARK_MODEL=lite
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Admin panel (set to true to enable /admin, false or unset to disable)
# WARNING: no auth — only enable in dev; add BasicAuth before production
ADMIN_ENABLED=true

# OCR (requires: sudo apt install tesseract-ocr tesseract-ocr-chi-sim)
# Without tesseract, scanned PDFs will return empty text
OCR_OUTPUT_DIR=data/ocr_output
