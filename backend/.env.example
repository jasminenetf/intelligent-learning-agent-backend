# ── LLM Provider ──
# Options: deepseek, spark, mock
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Xfyun Spark (HTTP API) — OpenAI-compatible
SPARK_ENABLED=false
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_API_KEY=
SPARK_API_PASSWORD=
SPARK_MODEL=generalv3.5
SPARK_TIMEOUT_SECONDS=30
SPARK_FALLBACK_PROVIDER=deepseek

LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# ── Embedding ──
EMBEDDING_PROVIDER=hash_mock
EMBEDDING_DIM=384
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# ── Database ──
DATABASE_URL=sqlite:///./data/app.db
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=course_chunks

# ── Virtual Human / Digital Avatar ──
VIRTUAL_HUMAN_ENABLED=false
XFYUN_VH_API_KEY=
XFYUN_VH_API_SECRET=
XFYUN_VH_BASE_URL=https://vms.cn-huadong-1.xf-yun.com
XFYUN_VH_AVATAR_ID=
XFYUN_VH_VOICE_ID=x4_xiaoxuan
VH_TIMEOUT_SECONDS=30

# ── Other ──
APP_NAME=intelligent-learning-agent
APP_ENV=development
BACKEND_PORT=8000
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FILE_UPLOAD_MAX_MB=80
ADMIN_ENABLED=true
GENERATED_DIR=./data/generated
OCR_OUTPUT_DIR=data/ocr_output
